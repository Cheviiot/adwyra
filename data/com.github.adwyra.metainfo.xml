  <name>Adwyra</name>
  <name xml:lang="ru">Adwyra</name>
  
  <summary>Elegant application launcher for Linux</summary>
  <summary xml:lang="ru">Элегантный лаунчер приложений для Linux</summary>
  
  <description>
    <p>
      Adwyra is a minimalist and fast way to launch applications on Linux.
      A beautiful grid of icons, instant search, and no clutter.
    </p>
    <p xml:lang="ru">
      Adwyra — минималистичный и быстрый способ запускать приложения.
      Красивая сетка иконок, мгновенный поиск и никаких лишних элементов.
    </p>
    <p>Features:</p>
    <ul>
      <li>Grid view of all applications with icons</li>
      <li>Application folders with drag and drop</li>
      <li>Horizontal pages navigation</li>
      <li>Pin favorite apps (right-click menu)</li>
      <li>Instant search filtering</li>
      <li>Native GNOME/Adwaita design</li>
      <li>Keyboard shortcuts (Ctrl+F, Esc)</li>
      <li>Global hotkey support (--toggle)</li>
      <li>Auto-close on focus loss</li>
      <li>Customizable settings</li>
    </ul>
  </description>
  
  <categories>
    <category>Utility</category>
    <category>GTK</category>
  </categories>
  
  <keywords>
    <keyword>launcher</keyword>
    <keyword>applications</keyword>
    <keyword>grid</keyword>
    <keyword xml:lang="ru">лаунчер</keyword>
    <keyword xml:lang="ru">приложения</keyword>
    <keyword xml:lang="ru">сетка</keyword>
  </keywords>
  
  <url type="homepage">https://github.com/cheviiot/adwyra</url>
  <url type="bugtracker">https://github.com/cheviiot/adwyra/issues</url>
  
  <launchable type="desktop-id">com.github.adwyra.desktop</launchable>
  
  <provides>
