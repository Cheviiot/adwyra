#!/bin/bash
# Staplerfile для Adwyra

name='adwyra'
version='0.1.0'
release=1
summary='Application launcher inspired by macOS Launchpad'
desc='Adwyra is a modern application launcher for Linux desktops,
inspired by macOS Launchpad. It provides a beautiful grid view of all
installed applications with instant search and pinning support.'
homepage='https://github.com/cheviiot/adwyra'
maintainer='Cheviiot <cheviiot@example.com>'
architectures=('all')
license=('GPL-3.0-or-later')
group='Graphical desktop/GNOME'

# Зависимости для запуска
deps=(
    'python3'
    'gtk4'
    'libadwaita'
)
deps_debian=(
    'python3'
    'python3-gi'
    'gir1.2-gtk-4.0'
    'gir1.2-adw-1'
)
deps_ubuntu=("${deps_debian[@]}")
deps_fedora=(
    'python3'
    'python3-gobject'
    'gtk4'
    'libadwaita'
)
deps_arch=(
    'python'
    'python-gobject'
    'gtk4'
    'libadwaita'
)
deps_altlinux=(
    'python3'
    'python3-module-pygobject3'
    'libgtk4'
    'libadwaita'
)
deps_opensuse=(
    'python3'
    'python3-gobject'
    'gtk4'
    'libadwaita'
)

# Источники
sources=(
    'git+https://github.com/cheviiot/adwyra.git#tag=v${version}'
)
checksums=(
    'SKIP'
)

# AppStream
appstream_app_id='com.github.adwyra.launcher'

package() {
    # Бинарный файл
    install -Dm755 "${srcdir}/adwyra/src/adwyra-launcher" "${pkgdir}/usr/bin/adwyra"
    
    # Python модуль
    install -dm755 "${pkgdir}/usr/lib/adwyra"
    cp -r "${srcdir}/adwyra/src/adwyra" "${pkgdir}/usr/lib/adwyra/"
    rm -rf "${pkgdir}/usr/lib/adwyra/adwyra/__pycache__"
    
    # Обновляем путь в бинарнике
    sed -i "s|sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))|sys.path.insert(0, '/usr/lib/adwyra')|" \
        "${pkgdir}/usr/bin/adwyra"
    
    # Desktop файл
    install-desktop "${srcdir}/adwyra/data/com.github.adwyra.launcher.desktop"
    
    # Иконка
    install -Dm644 "${srcdir}/adwyra/data/icons/hicolor/scalable/apps/com.github.adwyra.launcher.svg" \
        "${pkgdir}/usr/share/icons/hicolor/scalable/apps/com.github.adwyra.launcher.svg"
    
    # AppStream metainfo
    install -Dm644 "${srcdir}/adwyra/data/com.github.adwyra.launcher.metainfo.xml" \
        "${pkgdir}/usr/share/metainfo/com.github.adwyra.launcher.metainfo.xml"
    
    # Лицензия
    install-license "${srcdir}/adwyra/LICENSE"
}

files() {
    files-find \
        "/usr/bin/adwyra" \
        "/usr/lib/adwyra/**/*" \
        "/usr/share/applications/com.github.adwyra.launcher.desktop" \
        "/usr/share/icons/hicolor/scalable/apps/com.github.adwyra.launcher.svg" \
        "/usr/share/metainfo/com.github.adwyra.launcher.metainfo.xml" \
        "/usr/share/licenses/LICENSE"
}
