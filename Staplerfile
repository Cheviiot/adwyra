#!/bin/bash
# Staplerfile для Adwyra

name='adwyra'
version='0.3.0'
release=1
summary='Elegant application launcher for Linux'
desc='Adwyra is a minimalist and fast way to launch applications.
A beautiful grid of icons, instant search, app folders, pages,
drag & drop reordering and customizable settings.'
homepage='https://github.com/cheviiot/adwyra'
maintainer='Cheviiot <cheviiot@example.com>'
architectures=('all')
license=('GPL-3.0-or-later')
group='Graphical desktop/GNOME'

# Зависимости для запуска
deps=(
    'python3'
    'gtk4'
    'libadwaita'
)

# Скрипты установки/удаления
scripts=(
    ['preinstall']='scripts/preinstall.sh'
    ['postinstall']='scripts/postinstall.sh'
    ['postremove']='scripts/postremove.sh'
)
deps_debian=(
    'python3'
    'python3-gi'
    'gir1.2-gtk-4.0'
    'gir1.2-adw-1'
)
deps_ubuntu=("${deps_debian[@]}")
deps_fedora=(
    'python3'
    'python3-gobject'
    'gtk4'
    'libadwaita'
)
deps_arch=(
    'python'
    'python-gobject'
    'gtk4'
    'libadwaita'
)
deps_altlinux=(
    'python3'
    'python3-module-pygobject3'
    'libgtk4'
    'libadwaita'
)
deps_opensuse=(
    'python3'
    'python3-gobject'
    'gtk4'
    'libadwaita'
)

# Источники - используем архив для предотвращения проблем с кэшем
sources=(
    "https://github.com/Cheviiot/adwyra/archive/refs/tags/v${version}.tar.gz"
)
checksums=(
    'SKIP'
)

# AppStream
appstream_app_id='com.github.adwyra'

package() {
    # GitHub создаёт архив с именем репозитория (Adwyra)
    src="${srcdir}/Adwyra-${version}"
    
    # Бинарный файл
    install -Dm755 "${src}/adwyra" "${pkgdir}/usr/bin/adwyra"
    
    # Python модуль
    install -dm755 "${pkgdir}/usr/lib/adwyra"
    cp -r "${src}/src/adwyra" "${pkgdir}/usr/lib/adwyra/"
    find "${pkgdir}/usr/lib/adwyra" -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
    
    # Обновляем путь в бинарнике
    sed -i 's|os.path.join(os.path.dirname(os.path.abspath(__file__)), "src")|\x27/usr/lib/adwyra\x27|' \
        "${pkgdir}/usr/bin/adwyra"
    
    # Desktop файл
    install-desktop "${src}/data/com.github.adwyra.desktop"
    
    # Иконки всех размеров
    for size in 16 24 32 48 64 128 256 512; do
        install -Dm644 "${src}/data/icons/hicolor/${size}x${size}/apps/com.github.adwyra.png" \
            "${pkgdir}/usr/share/icons/hicolor/${size}x${size}/apps/com.github.adwyra.png"
    done
    
    # AppStream metainfo
    install -Dm644 "${src}/data/com.github.adwyra.metainfo.xml" \
        "${pkgdir}/usr/share/metainfo/com.github.adwyra.metainfo.xml"
    
    # Лицензия
    install-license "${src}/LICENSE"
}

files() {
    files-find \
        "/usr/bin/adwyra" \
        "/usr/lib/adwyra/adwyra/*.py" \
        "/usr/lib/adwyra/adwyra/core/*.py" \
        "/usr/lib/adwyra/adwyra/ui/*.py" \
        "/usr/lib/adwyra/adwyra/ui/widgets/*.py" \
        "/usr/lib/adwyra/adwyra/*.css" \
        "/usr/share/icons/hicolor/16x16/apps/com.github.adwyra.png" \
        "/usr/share/icons/hicolor/24x24/apps/com.github.adwyra.png" \
        "/usr/share/icons/hicolor/32x32/apps/com.github.adwyra.png" \
        "/usr/share/icons/hicolor/48x48/apps/com.github.adwyra.png" \
        "/usr/share/icons/hicolor/64x64/apps/com.github.adwyra.png" \
        "/usr/share/icons/hicolor/128x128/apps/com.github.adwyra.png" \
        "/usr/share/icons/hicolor/256x256/apps/com.github.adwyra.png" \
        "/usr/share/icons/hicolor/512x512/apps/com.github.adwyra.png" \
        "/usr/share/metainfo/com.github.adwyra.metainfo.xml"
    files-find-desktop
    files-find-license
}
